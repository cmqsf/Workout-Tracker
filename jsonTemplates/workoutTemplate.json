        "other": {
            "bsonType": "object",
            "description": "Details of other exercises",
            "properties": {
                "type": {
                    "bsonType": "string"
                }, 
                "description": {
                    "bsonType": "string", 
                    "description": "Details of the other workout"
                },
                "weight": {
                    "bsonType": "double"
                },
                "sets": {
                    "bsonType": "int"
                },
                "reps": {
                    "bsonType": "int"
                }
            }
